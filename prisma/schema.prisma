generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  phone         String?
  role          String   @default("COMPANY")
  createdAt     DateTime @default(now())

  // Profilo utente
  firstName     String?
  lastName      String?
  companyName   String?
  vatNumber     String?
  address       String?
  city          String?
  province      String?
  zipCode       String?
  country       String?  @default("IT")
  contactPerson String?
  avatarUrl     String?

  companyRequests     Request[] @relation("CompanyRequests")
  transporterRequests Request[] @relation("TransporterJobs")
}

model Request {
  id                    Int       @id @default(autoincrement())
  pickup                String
  delivery              String
  cargo                 String?
  description           String?
  price                 Int
  companyId             Int
  transporterId         Int?
  contactsUnlocked      Boolean   @default(false)
  unlockedByCompany     Boolean   @default(false)
  unlockedByTransporter Boolean   @default(false)
  acceptedAt            DateTime?
  status                String    @default("OPEN")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  company     User  @relation("CompanyRequests", fields: [companyId], references: [id])
  transporter User? @relation("TransporterJobs", fields: [transporterId], references: [id])
}
